# ============================================================
# .gitignore for WERS Revisit project
# ============================================================
# Raw WERS data must not be uploaded. UKDS End User Licence
# does not permit redistribution of the microdata.
# ============================================================

# ---- 1. Raw data (UKDS licensed, must not be uploaded) ----
00_data/raw/
00_data/processed/
*.dta
*.sav
*.rds
*.rda
*.RData

# ---- 2. R working files ------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata
.Renviron

# ---- 3. Operating system clutter ---------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- 4. Excel temp files -----------------------------------
~$*.xlsx
~$*.xls

# ---- 5. CSV files ------------------------------------------
# Ignore CSVs by default because working exports may contain
# row-level data. Allow final aggregated output tables only.
*.csv
!04_outputs/tables/*.csv

# ---- 6. Temporary outputs ----------------------------------
*.log
*.tmp
*.bak

# ---- 7. Archive working files not ready for public repo ----
99_archive/*
!99_archive/README.md

# ---- 8. Word report drafts not committed until final -------
06_report/*.docx

# ---- 9. Local operational logs -----------------------------
03_QA/daily_work_log.xlsx